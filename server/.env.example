PORT=3001
FRONTEND_URL=http://localhost:5173

# NeonDB — copy from your Neon project settings
DATABASE_URL=postgresql://user:pass@host.neon.tech/perch?sslmode=require

# Stack Auth — from app.stack-auth.com after enabling Neon Auth
STACK_PROJECT_ID=
STACK_SECRET_SERVER_KEY=

# eBay Developer — from developer.ebay.com
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# Raw callback URL registered in eBay portal
EBAY_REDIRECT_URI=http://localhost:3001/auth/ebay/callback
# RuName generated by eBay portal (used as redirect_uri in OAuth URL)
EBAY_RUNAME=
# sandbox or production
EBAY_ENVIRONMENT=sandbox

# Random secret for signing eBay OAuth state JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
