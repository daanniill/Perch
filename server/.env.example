PORT=3001
FRONTEND_URL=http://localhost:5173

# Supabase — from your project dashboard → Settings → API
SUPABASE_URL=
# service_role key (keep secret — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase PostgreSQL — from Project Settings → Database → Connection string (use the "URI" format)
DATABASE_URL=

# eBay Developer — from developer.ebay.com
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# Raw callback URL registered in eBay portal
EBAY_REDIRECT_URI=http://localhost:3001/auth/ebay/callback
# RuName generated by eBay portal (used as redirect_uri in OAuth URL, not the raw URL)
EBAY_RUNAME=
# sandbox or production
EBAY_ENVIRONMENT=sandbox

# Random secret for signing eBay OAuth state JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
