PORT=3001
FRONTEND_URL=http://localhost:5173

# Supabase — from your project dashboard → Settings → API
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=

# Supabase PostgreSQL — from Project Settings → Database → Connection string (URI)
DATABASE_URL=

# eBay Developer — from developer.ebay.com
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# Raw callback URL registered in eBay portal
EBAY_REDIRECT_URI=http://localhost:3001/auth/ebay/callback
# RuName generated by eBay portal (used as redirect_uri in OAuth URL, not the raw URL)
EBAY_RUNAME=
# sandbox or production
EBAY_ENVIRONMENT=sandbox

# Random secret for signing eBay OAuth state JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Groq — from console.groq.com → API Keys
GROQ_API_KEY=
